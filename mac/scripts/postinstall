#!/bin/bash
# ClaudeCode Launchpad CLI — macOS dependency installer (postinstall)
# Runs as root after .pkg installation

# Do NOT use set -e — we handle errors per-step so one failure doesn't kill the whole install
LOG_FILE="/tmp/kivun_install.log"
REAL_USER="${SUDO_USER:-$(stat -f '%Su' /dev/console)}"
REAL_HOME=$(dscl . -read "/Users/$REAL_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
REAL_HOME="${REAL_HOME:-/Users/$REAL_USER}"

log() { echo "[$(date '+%H:%M:%S')] $1" | tee -a "$LOG_FILE"; }

# Run command as the real user with proper PATH including Homebrew
run_as_user() {
    sudo -u "$REAL_USER" bash -l -c "$1"
}

log "=== ClaudeCode Launchpad CLI macOS Installer ==="
log "User: $REAL_USER | Home: $REAL_HOME"
log "Arch: $(uname -m) | macOS: $(sw_vers -productVersion)"

# --- Xcode Command Line Tools (required for Homebrew & Git) ---
log "Checking Xcode CLT..."
CLT_PATH=$(xcode-select -p 2>&1) || true
log "xcode-select -p: '$CLT_PATH' (exit: $?)"

if ! xcode-select -p &>/dev/null; then
    log "CLT not installed — attempting non-interactive install via softwareupdate"
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress

    log "Running: softwareupdate -l (listing available updates)..."
    SWUPDATE_OUTPUT=$(softwareupdate -l 2>&1) || true
    log "softwareupdate -l output:"
    echo "$SWUPDATE_OUTPUT" >> "$LOG_FILE"

    CLT_LABEL=$(echo "$SWUPDATE_OUTPUT" | grep 'Label:.*Command Line Tools' | sed 's/.*Label: //' | sed 's/[[:space:]]*$//' | head -1)
    log "Parsed CLT label: '$CLT_LABEL'"

    if [ -n "$CLT_LABEL" ]; then
        log "Installing: $CLT_LABEL (this may take 5-10 minutes)..."
        softwareupdate -i "$CLT_LABEL" 2>&1 | tee -a "$LOG_FILE"
        SW_EXIT=$?
        log "softwareupdate -i exit code: $SW_EXIT"
    else
        log "WARNING: No CLT package found in Software Update catalog"
        log "Attempting xcode-select --install as fallback..."
        xcode-select --install 2>&1 | tee -a "$LOG_FILE" || true
    fi

    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress

    if xcode-select -p &>/dev/null; then
        log "Xcode CLT installed at: $(xcode-select -p)"
    else
        log "WARNING: Xcode CLT still not detected after install attempt"
    fi
else
    log "Xcode CLT already installed at: $CLT_PATH"
fi

# --- Homebrew ---
log "Checking Homebrew..."
BREW_PATH=$(run_as_user "command -v brew" 2>&1) || true
log "brew path: '$BREW_PATH'"

if ! run_as_user "command -v brew" &>/dev/null; then
    log "Homebrew not found — installing..."

    # Pre-checks
    log "Pre-checks before Homebrew install:"
    log "  curl: $(which curl 2>&1)"
    log "  git: $(run_as_user 'command -v git' 2>&1 || echo 'not found')"
    log "  xcode-select -p: $(xcode-select -p 2>&1 || echo 'not installed')"
    log "  Running as user: $REAL_USER"
    log "  User HOME: $REAL_HOME"
    log "  User shell: $(dscl . -read /Users/$REAL_USER UserShell 2>/dev/null | awk '{print $2}' || echo 'unknown')"

    # The Homebrew installer checks `sudo -n` BEFORE doing anything else.
    # In a .pkg postinstall context there is no TTY, so sudo -n always fails
    # ("Need sudo access on macOS"). Fix: temporarily grant passwordless sudo.
    log "Granting temporary passwordless sudo for Homebrew install..."
    SUDOERS_TMP="/etc/sudoers.d/kivun-brew-temp"

    # SECURITY FIX: Ensure cleanup happens even if script is interrupted
    trap 'rm -f "$SUDOERS_TMP"; log "Cleaned up temporary sudo file"' EXIT ERR INT TERM

    echo "$REAL_USER ALL=(ALL) NOPASSWD:ALL" > "$SUDOERS_TMP"
    chmod 0440 "$SUDOERS_TMP"
    log "  Created $SUDOERS_TMP"

    # Also pre-create Homebrew prefix directory
    if [[ $(uname -m) == "arm64" ]]; then
        BREW_PREFIX="/opt/homebrew"
    else
        BREW_PREFIX="/usr/local/Homebrew"
    fi
    mkdir -p "$BREW_PREFIX" 2>/dev/null || true
    chown -R "$REAL_USER:admin" "$BREW_PREFIX" 2>/dev/null || true
    log "  $BREW_PREFIX owner: $(ls -ld "$BREW_PREFIX" 2>&1)"

    log "Running Homebrew installer (NONINTERACTIVE=1)..."
    BREW_OUTPUT=$(run_as_user 'NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"' 2>&1)
    BREW_EXIT=$?

    # Remove temporary sudo access immediately
    rm -f "$SUDOERS_TMP"
    trap - EXIT ERR INT TERM
    log "  Removed $SUDOERS_TMP"

    log "Homebrew installer exit code: $BREW_EXIT"
    log "Homebrew installer output:"
    echo "$BREW_OUTPUT" >> "$LOG_FILE"

    # Log last 20 lines to console too
    echo "$BREW_OUTPUT" | tail -20 | while IFS= read -r line; do log "  brew: $line"; done

    if [ $BREW_EXIT -eq 0 ]; then
        # Add brew to shell profile for Apple Silicon
        if [[ $(uname -m) == "arm64" ]]; then
            if ! grep -q "brew shellenv" "$REAL_HOME/.zprofile" 2>/dev/null; then
                run_as_user 'echo "eval \"\$(/opt/homebrew/bin/brew shellenv)\"" >> ~/.zprofile'
                log "Added brew shellenv to .zprofile"
            fi
        fi
        log "Homebrew installed successfully"
    else
        log "ERROR: Homebrew installation failed (exit code: $BREW_EXIT)"
        log "Check full output in $LOG_FILE for details"
    fi
else
    BREW_VER=$(run_as_user 'brew --version' 2>/dev/null | head -1)
    log "Homebrew already installed: $BREW_VER"
fi

# --- Node.js ---
if ! run_as_user "command -v node" &>/dev/null; then
    log "Installing Node.js..."
    if run_as_user "brew install node"; then
        log "Node.js $(run_as_user 'node --version' 2>/dev/null) installed"
    else
        log "ERROR: Node.js installation failed"
    fi
else
    log "Node.js $(run_as_user 'node --version' 2>/dev/null) already installed — skipping"
fi

# --- Git ---
if ! run_as_user "command -v git" &>/dev/null; then
    log "Installing Git..."
    if run_as_user "brew install git"; then
        log "Git installed"
    else
        log "ERROR: Git installation failed"
    fi
else
    log "Git already installed — skipping"
fi

# --- Claude Code ---
if ! run_as_user "command -v claude" &>/dev/null; then
    log "Installing Claude Code via Anthropic native installer..."
    CLAUDE_INSTALL_SCRIPT="/tmp/claude-install.sh"
    if curl -fsSL -o "$CLAUDE_INSTALL_SCRIPT" "https://claude.ai/install.sh" 2>&1 | tee -a "$LOG_FILE"; then
        chmod +x "$CLAUDE_INSTALL_SCRIPT"
        if run_as_user "bash '$CLAUDE_INSTALL_SCRIPT'"; then
            log "Claude Code installed"
        else
            log "ERROR: Claude Code installation failed"
        fi
        rm -f "$CLAUDE_INSTALL_SCRIPT"
    else
        log "ERROR: Failed to download Claude Code installer"
    fi
else
    log "Claude Code already installed — skipping"
fi

# --- Statusline ---
STATUSLINE_DIR="/usr/local/share/kivun"
STATUSLINE_SRC="$(dirname "$0")/statusline.mjs"
log "Installing statusline..."
mkdir -p "$STATUSLINE_DIR" 2>/dev/null || true
if [ -f "$STATUSLINE_SRC" ]; then
    cp "$STATUSLINE_SRC" "$STATUSLINE_DIR/statusline.mjs"
    chmod 644 "$STATUSLINE_DIR/statusline.mjs"
    log "Statusline copied to $STATUSLINE_DIR/statusline.mjs"
else
    log "WARNING: statusline.mjs not found in package — skipping"
fi

# Set CLAUDE_CODE_STATUSLINE in user's shell profile
SHELL_RC="$REAL_HOME/.zshrc"
if [ -f "$REAL_HOME/.bashrc" ] && [ ! -f "$REAL_HOME/.zshrc" ]; then
    SHELL_RC="$REAL_HOME/.bashrc"
fi
# Create shell rc if it doesn't exist
run_as_user "touch '$SHELL_RC'" 2>/dev/null || true
EXPORT_LINE="export CLAUDE_CODE_STATUSLINE=\"$STATUSLINE_DIR/statusline.mjs\""
if ! grep -q "CLAUDE_CODE_STATUSLINE" "$SHELL_RC" 2>/dev/null; then
    run_as_user "echo '' >> '$SHELL_RC' && echo '# ClaudeCode Launchpad CLI statusline' >> '$SHELL_RC' && echo '$EXPORT_LINE' >> '$SHELL_RC'"
    log "CLAUDE_CODE_STATUSLINE added to $SHELL_RC"
else
    log "CLAUDE_CODE_STATUSLINE already in $SHELL_RC — skipping"
fi

# Configure statusline in Claude Code settings.json
CONFIGURE_SCRIPT="$(dirname "$0")/configure-statusline.js"
if [ -f "$CONFIGURE_SCRIPT" ]; then
    log "Configuring statusline in Claude Code settings..."
    run_as_user "node '$CONFIGURE_SCRIPT' '$STATUSLINE_DIR/statusline.mjs'" 2>/dev/null
    if [ $? -eq 0 ]; then
        log "Statusline configured in Claude Code settings"
    else
        log "WARNING: Could not configure statusline in settings"
    fi
else
    log "WARNING: configure-statusline.js not found in package"
fi

# --- Configuration File ---
log "Creating configuration file..."
CONFIG_DIR="$REAL_HOME/Library/Application Support/ClaudeCode-Launchpad"
CONFIG_FILE="$CONFIG_DIR/config.txt"
run_as_user "mkdir -p '$CONFIG_DIR'" 2>/dev/null || true
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" << 'CONFIG'
# ClaudeCode Launchpad CLI Configuration

# Claude Code response language
# Options: english, hebrew, arabic, persian, urdu, kurdish, pashto, sindhi, yiddish, syriac, dhivehi, nko, adlam, mandaic, samaritan, dari, uyghur, balochi, kashmiri, shahmukhi, azeri_south, jawi, hausa_ajami, rohingya, turoyo
# Default: english
RESPONSE_LANGUAGE=english

# Terminal color theme
# Options: kivun (light-blue), default (keep your terminal theme)
TERMINAL_COLOR=kivun

# Claude startup flags (optional, applied on every launch)
# Example: CLAUDE_FLAGS=--continue
CLAUDE_FLAGS=
CONFIG
    chown "$REAL_USER" "$CONFIG_FILE"
    log "Configuration file created at $CONFIG_FILE"
else
    log "Configuration file already exists — skipping"
fi

# --- Desktop Shortcut with Folder Picker ---
log "Creating desktop shortcut..."
# Remove old-name shortcut from previous installs
rm -f "$REAL_HOME/Desktop/Kivun Terminal.command"
SHORTCUT_PATH="$REAL_HOME/Desktop/ClaudeCode Launchpad CLI.command"
cat > "$SHORTCUT_PATH" << 'SCRIPT'
#!/bin/bash
# ClaudeCode Launchpad CLI — launches Claude Code with folder picker

CONFIG_DIR="$HOME/Library/Application Support/ClaudeCode-Launchpad"
CONFIG_FILE="$CONFIG_DIR/config.txt"
STATUSLINE_DIR="/usr/local/share/kivun"

# Statusline
export CLAUDE_CODE_STATUSLINE="$STATUSLINE_DIR/statusline.mjs"

# Read configuration
RESPONSE_LANGUAGE="english"
TERMINAL_COLOR="kivun"
CLAUDE_FLAGS=""
if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        # Trim whitespace
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        case "$key" in
            RESPONSE_LANGUAGE) RESPONSE_LANGUAGE="$value" ;;
            TERMINAL_COLOR) TERMINAL_COLOR="$value" ;;
            CLAUDE_FLAGS) CLAUDE_FLAGS="$value" ;;
        esac
    done < "$CONFIG_FILE"
fi

# Apply light blue background if enabled
if [ "$TERMINAL_COLOR" = "kivun" ]; then
    osascript -e '
    tell application "Terminal"
        tell front window
            set background color of selected tab to {51400, 59110, 65535}
            set normal text color of selected tab to {0, 0, 0}
            set bold text color of selected tab to {0, 0, 0}
            set cursor color of selected tab to {6425, 6425, 6425}
        end tell
    end tell
    ' 2>/dev/null
fi

clear
echo "ClaudeCode Launchpad CLI"
echo ""

# Folder picker
FOLDER=$(osascript -e 'tell application "Finder"
    try
        set selectedFolder to choose folder with prompt "Select a folder to open with Claude Code:"
        return POSIX path of selectedFolder
    on error
        return ""
    end try
end tell' 2>/dev/null)

if [ -z "$FOLDER" ]; then
    echo "No folder selected. Exiting..."
    read -p "Press Enter to close..."
    exit 0
fi

cd "$FOLDER" || exit 1

# Build language prompt argument
LANG_PROMPT=""
case "$RESPONSE_LANGUAGE" in
    hebrew) LANG_PROMPT="--append-system-prompt \"Always respond in Hebrew.\"" ;;
    arabic) LANG_PROMPT="--append-system-prompt \"Always respond in Arabic.\"" ;;
    persian) LANG_PROMPT="--append-system-prompt \"Always respond in Persian (Farsi).\"" ;;
    urdu) LANG_PROMPT="--append-system-prompt \"Always respond in Urdu.\"" ;;
    kurdish) LANG_PROMPT="--append-system-prompt \"Always respond in Kurdish.\"" ;;
    pashto) LANG_PROMPT="--append-system-prompt \"Always respond in Pashto.\"" ;;
    sindhi) LANG_PROMPT="--append-system-prompt \"Always respond in Sindhi.\"" ;;
    yiddish) LANG_PROMPT="--append-system-prompt \"Always respond in Yiddish.\"" ;;
    syriac) LANG_PROMPT="--append-system-prompt \"Always respond in Syriac.\"" ;;
    dhivehi) LANG_PROMPT="--append-system-prompt \"Always respond in Dhivehi.\"" ;;
    nko) LANG_PROMPT="--append-system-prompt \"Always respond in N'Ko.\"" ;;
    adlam) LANG_PROMPT="--append-system-prompt \"Always respond in Adlam.\"" ;;
    mandaic) LANG_PROMPT="--append-system-prompt \"Always respond in Mandaic.\"" ;;
    samaritan) LANG_PROMPT="--append-system-prompt \"Always respond in Samaritan.\"" ;;
    dari) LANG_PROMPT="--append-system-prompt \"Always respond in Dari.\"" ;;
    uyghur) LANG_PROMPT="--append-system-prompt \"Always respond in Uyghur.\"" ;;
    balochi) LANG_PROMPT="--append-system-prompt \"Always respond in Balochi.\"" ;;
    kashmiri) LANG_PROMPT="--append-system-prompt \"Always respond in Kashmiri.\"" ;;
    shahmukhi) LANG_PROMPT="--append-system-prompt \"Always respond in Shahmukhi (Punjabi).\"" ;;
    azeri_south) LANG_PROMPT="--append-system-prompt \"Always respond in South Azerbaijani.\"" ;;
    jawi) LANG_PROMPT="--append-system-prompt \"Always respond in Jawi (Malay).\"" ;;
    hausa_ajami) LANG_PROMPT="--append-system-prompt \"Always respond in Hausa (Ajami script).\"" ;;
    rohingya) LANG_PROMPT="--append-system-prompt \"Always respond in Rohingya.\"" ;;
    turoyo) LANG_PROMPT="--append-system-prompt \"Always respond in Turoyo.\"" ;;
esac

echo "Starting Claude Code in: $FOLDER"
echo ""

# Launch Claude with all flags (SECURITY: avoid eval, use proper argument passing)
if [ -n "$LANG_PROMPT" ]; then
    if [ -n "$CLAUDE_FLAGS" ]; then
        claude --append-system-prompt "$LANG_PROMPT" $CLAUDE_FLAGS
    else
        claude --append-system-prompt "$LANG_PROMPT"
    fi
else
    if [ -n "$CLAUDE_FLAGS" ]; then
        claude $CLAUDE_FLAGS
    else
        claude
    fi
fi
SCRIPT
chmod +x "$SHORTCUT_PATH"
chown "$REAL_USER" "$SHORTCUT_PATH"
log "Desktop shortcut created at $SHORTCUT_PATH"

# --- Finder Quick Action (Right-Click Context Menu) ---
log "Creating Finder Quick Action..."
WORKFLOW_DIR="$REAL_HOME/Library/Services"
WORKFLOW_PATH="$WORKFLOW_DIR/Open with ClaudeCode Launchpad.workflow"
run_as_user "mkdir -p '$WORKFLOW_DIR'" 2>/dev/null || true

# Remove old workflow if it exists
rm -rf "$WORKFLOW_PATH" 2>/dev/null || true

# Create Automator workflow directory structure
mkdir -p "$WORKFLOW_PATH/Contents"
cat > "$WORKFLOW_PATH/Contents/Info.plist" << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSServices</key>
    <array>
        <dict>
            <key>NSMenuItem</key>
            <dict>
                <key>default</key>
                <string>Open with ClaudeCode Launchpad</string>
            </dict>
            <key>NSMessage</key>
            <string>runWorkflowAsService</string>
            <key>NSRequiredContext</key>
            <dict>
                <key>NSApplicationIdentifier</key>
                <string>com.apple.finder</string>
            </dict>
            <key>NSSendFileTypes</key>
            <array>
                <string>public.folder</string>
            </array>
        </dict>
    </array>
    <key>CFBundleIdentifier</key>
    <string>com.noambrand.claudecode-launchpad-quickaction</string>
    <key>CFBundleName</key>
    <string>Open with ClaudeCode Launchpad</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
</dict>
</plist>
PLIST

mkdir -p "$WORKFLOW_PATH/Contents/QuickLook"
cat > "$WORKFLOW_PATH/Contents/document.wflow" << 'WFLOW'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>AMApplicationBuild</key>
    <string>521</string>
    <key>AMApplicationVersion</key>
    <string>2.10</string>
    <key>AMDocumentVersion</key>
    <string>2</string>
    <key>actions</key>
    <array>
        <dict>
            <key>action</key>
            <dict>
                <key>AMAccepts</key>
                <dict>
                    <key>Container</key>
                    <string>List</string>
                    <key>Optional</key>
                    <true/>
                    <key>Types</key>
                    <array>
                        <string>com.apple.cocoa.path</string>
                    </array>
                </dict>
                <key>AMActionVersion</key>
                <string>1.0</string>
                <key>AMApplication</key>
                <array>
                    <string>Automator</string>
                </array>
                <key>AMParameterProperties</key>
                <dict>
                    <key>source</key>
                    <dict/>
                </dict>
                <key>AMProvides</key>
                <dict>
                    <key>Container</key>
                    <string>List</string>
                    <key>Types</key>
                    <array>
                        <string>com.apple.cocoa.path</string>
                    </array>
                </dict>
                <key>ActionBundlePath</key>
                <string>/System/Library/Automator/Run Shell Script.action</string>
                <key>ActionName</key>
                <string>Run Shell Script</string>
                <key>ActionParameters</key>
                <dict>
                    <key>COMMAND_STRING</key>
                    <string>#!/bin/bash
CONFIG_DIR="$HOME/Library/Application Support/ClaudeCode-Launchpad"
CONFIG_FILE="$CONFIG_DIR/config.txt"
STATUSLINE_DIR="/usr/local/share/kivun"

# Get folder path from input
FOLDER="$1"

# Read configuration
RESPONSE_LANGUAGE="english"
TERMINAL_COLOR="kivun"
CLAUDE_FLAGS=""
if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        case "$key" in
            RESPONSE_LANGUAGE) RESPONSE_LANGUAGE="$value" ;;
            TERMINAL_COLOR) TERMINAL_COLOR="$value" ;;
            CLAUDE_FLAGS) CLAUDE_FLAGS="$value" ;;
        esac
    done &lt; "$CONFIG_FILE"
fi

# Build language prompt
LANG_PROMPT=""
case "$RESPONSE_LANGUAGE" in
    hebrew) LANG_PROMPT="--append-system-prompt \"Always respond in Hebrew.\"" ;;
    arabic) LANG_PROMPT="--append-system-prompt \"Always respond in Arabic.\"" ;;
    persian) LANG_PROMPT="--append-system-prompt \"Always respond in Persian (Farsi).\"" ;;
    urdu) LANG_PROMPT="--append-system-prompt \"Always respond in Urdu.\"" ;;
    kurdish) LANG_PROMPT="--append-system-prompt \"Always respond in Kurdish.\"" ;;
    pashto) LANG_PROMPT="--append-system-prompt \"Always respond in Pashto.\"" ;;
    sindhi) LANG_PROMPT="--append-system-prompt \"Always respond in Sindhi.\"" ;;
    yiddish) LANG_PROMPT="--append-system-prompt \"Always respond in Yiddish.\"" ;;
    syriac) LANG_PROMPT="--append-system-prompt \"Always respond in Syriac.\"" ;;
    dhivehi) LANG_PROMPT="--append-system-prompt \"Always respond in Dhivehi.\"" ;;
    nko) LANG_PROMPT="--append-system-prompt \"Always respond in N'Ko.\"" ;;
    adlam) LANG_PROMPT="--append-system-prompt \"Always respond in Adlam.\"" ;;
    mandaic) LANG_PROMPT="--append-system-prompt \"Always respond in Mandaic.\"" ;;
    samaritan) LANG_PROMPT="--append-system-prompt \"Always respond in Samaritan.\"" ;;
    dari) LANG_PROMPT="--append-system-prompt \"Always respond in Dari.\"" ;;
    uyghur) LANG_PROMPT="--append-system-prompt \"Always respond in Uyghur.\"" ;;
    balochi) LANG_PROMPT="--append-system-prompt \"Always respond in Balochi.\"" ;;
    kashmiri) LANG_PROMPT="--append-system-prompt \"Always respond in Kashmiri.\"" ;;
    shahmukhi) LANG_PROMPT="--append-system-prompt \"Always respond in Shahmukhi (Punjabi).\"" ;;
    azeri_south) LANG_PROMPT="--append-system-prompt \"Always respond in South Azerbaijani.\"" ;;
    jawi) LANG_PROMPT="--append-system-prompt \"Always respond in Jawi (Malay).\"" ;;
    hausa_ajami) LANG_PROMPT="--append-system-prompt \"Always respond in Hausa (Ajami script).\"" ;;
    rohingya) LANG_PROMPT="--append-system-prompt \"Always respond in Rohingya.\"" ;;
    turoyo) LANG_PROMPT="--append-system-prompt \"Always respond in Turoyo.\"" ;;
esac

# Apply colors if enabled
if [ "$TERMINAL_COLOR" = "kivun" ]; then
    osascript -e '
    tell application "Terminal"
        tell front window
            set background color of selected tab to {51400, 59110, 65535}
            set normal text color of selected tab to {0, 0, 0}
            set bold text color of selected tab to {0, 0, 0}
            set cursor color of selected tab to {6425, 6425, 6425}
        end tell
    end tell
    ' 2&gt;/dev/null
fi

# Open Terminal and launch Claude (SECURITY: proper quoting for flags)
export CLAUDE_CODE_STATUSLINE="$STATUSLINE_DIR/statusline.mjs"

# Build command with proper argument handling
CMD="cd '$FOLDER' &amp;&amp; clear &amp;&amp; echo 'ClaudeCode Launchpad CLI' &amp;&amp; echo ''"
if [ -n "$LANG_PROMPT" ]; then
    CMD="$CMD &amp;&amp; claude --append-system-prompt '$LANG_PROMPT'"
else
    CMD="$CMD &amp;&amp; claude"
fi
if [ -n "$CLAUDE_FLAGS" ]; then
    CMD="$CMD $CLAUDE_FLAGS"
fi

osascript -e "tell application \"Terminal\"
    activate
    do script \"$CMD\"
end tell"
</string>
                    <key>CheckedForUserDefaultShell</key>
                    <true/>
                    <key>inputMethod</key>
                    <integer>1</integer>
                    <key>shell</key>
                    <string>/bin/bash</string>
                    <key>source</key>
                    <string></string>
                </dict>
                <key>BundleIdentifier</key>
                <string>com.apple.RunShellScript</string>
                <key>CFBundleVersion</key>
                <string>1.0</string>
                <key>CanShowSelectedItemsWhenRun</key>
                <false/>
                <key>CanShowWhenRun</key>
                <true/>
                <key>Category</key>
                <array>
                    <string>AMCategoryUtilities</string>
                </array>
                <key>Class Name</key>
                <string>RunShellScriptAction</string>
                <key>InputUUID</key>
                <string>00000000-0000-0000-0000-000000000000</string>
                <key>Keywords</key>
                <array>
                    <string>Shell</string>
                    <string>Script</string>
                    <string>Command</string>
                    <string>Run</string>
                    <string>Unix</string>
                </array>
                <key>OutputUUID</key>
                <string>00000000-0000-0000-0000-000000000001</string>
                <key>UUID</key>
                <string>00000000-0000-0000-0000-000000000002</string>
                <key>UnlocalizedApplications</key>
                <array>
                    <string>Automator</string>
                </array>
                <key>arguments</key>
                <dict>
                    <key>0</key>
                    <dict>
                        <key>default value</key>
                        <integer>0</integer>
                        <key>name</key>
                        <string>inputMethod</string>
                        <key>required</key>
                        <string>0</string>
                        <key>type</key>
                        <string>0</string>
                        <key>uuid</key>
                        <string>0</string>
                    </dict>
                    <key>1</key>
                    <dict>
                        <key>default value</key>
